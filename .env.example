# --- LLM provider ---------------------------------------------------------
# Options: "groq" (free, recommended) or "anthropic" (paid)
# If unset, picks groq when GROQ_API_KEY is present, else anthropic.
LLM_PROVIDER=groq

# --- Groq (free) — get a key at https://console.groq.com ------------------
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# --- Anthropic (paid) -----------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6

# --- Embeddings + vector store -------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_DIR=./knowledge_base/store
KB_COLLECTION=support_kb
